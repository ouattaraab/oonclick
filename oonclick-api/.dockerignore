# Version control
.git/
.gitignore

# Environment secrets — never bake into the image
.env
.env.*
!.env.example

# PHP / Composer — reinstalled during build
vendor/

# Node / Vite — asset build happens inside the assets stage
node_modules/

# Laravel runtime directories — created at container startup
storage/logs/*
storage/framework/cache/*
storage/framework/sessions/*
storage/framework/views/*
bootstrap/cache/*.php

# Docker files themselves (no need inside image)
docker/
docker-compose*.yml
Dockerfile

# CI/CD
.github/

# Development tooling
Makefile
*.md
*.sh

# IDE / OS artifacts
.idea/
.vscode/
.DS_Store
Thumbs.db
