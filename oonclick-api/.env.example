APP_NAME="oon.click"
APP_ENV=local
APP_KEY=APP_KEY_REMOVED
# PRODUCTION : mettre APP_DEBUG=false impérativement
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Base de données — MySQL Hostinger en production
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=oonclick
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
# PRODUCTION : mettre SESSION_ENCRYPT=true
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# PRODUCTION : mettre SESSION_SECURE_COOKIE=true
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=pusher
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file

# Sanctum — expiration des tokens API (en minutes, 1440 = 24h)
SANCTUM_TOKEN_EXPIRATION=1440

# Pusher (temps réel — free tier)
PUSHER_APP_ID=VOTRE_ID
PUSHER_APP_KEY=VOTRE_KEY
PUSHER_APP_SECRET=VOTRE_SECRET
PUSHER_APP_CLUSTER=eu
PUSHER_SCHEME=https
VITE_PUSHER_APP_KEY=VOTRE_KEY
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# DÉVELOPPEMENT : log uniquement (aucun email réel envoyé)
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@oon.click"
MAIL_FROM_NAME="${APP_NAME}"

# PRODUCTION : configurer SMTP Hostinger
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.hostinger.com
# MAIL_PORT=465
# MAIL_USERNAME=noreply@oon.click
# MAIL_PASSWORD=your_password
# MAIL_ENCRYPTION=ssl
# MAIL_FROM_ADDRESS="noreply@oon.click"
# MAIL_FROM_NAME="${APP_NAME}"

# Cloudflare R2 (stockage médias publicitaires)
AWS_ACCESS_KEY_ID=VOTRE_R2_KEY
AWS_SECRET_ACCESS_KEY=VOTRE_R2_SECRET
AWS_DEFAULT_REGION=auto
AWS_BUCKET=oonclick-media
AWS_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
CLOUDFLARE_CDN_URL=https://cdn.oon.click
MEDIA_DISK=r2

# Paystack
PAYSTACK_SECRET_KEY=sk_test_VOTRE_CLE
PAYSTACK_PUBLIC_KEY=pk_test_VOTRE_CLE
PAYSTACK_WEBHOOK_SECRET=

# Google OAuth (inscription/connexion web)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# SMS OTP (Africa's Talking — meilleure couverture CI)
SMS_PROVIDER=africastalking
AT_API_KEY=VOTRE_AT_KEY
AT_USERNAME=sandbox

# Tarifs plateforme (FCFA)
COST_PER_VIEW=100
SUBSCRIBER_EARN=60
PLATFORM_FEE=40
SIGNUP_BONUS=500
MIN_WITHDRAWAL=5000
MAX_VIEWS_PER_HOUR=10
MAX_VIEWS_PER_DAY=30

# Firebase Cloud Messaging
FIREBASE_CREDENTIALS=storage/firebase-service-account.json
FIREBASE_PROJECT_ID=oonclick-9fe4c
FCM_VAPID_KEY=BCcsgSeFYK_SHeREUlwOZUBUaVRJlyX7puO-tB7p72-Ce-eIBV6-lGZKQiZCcCPDm4i0iNTlpftsDdHNBCkRGik

VITE_APP_NAME="${APP_NAME}"

# Sentry error & performance monitoring
# Laissez vide pour désactiver Sentry (développement local, CI)
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_SAMPLE_RATE=1.0
# Release tag — rempli automatiquement en CI (ex: git SHA)
SENTRY_RELEASE=
