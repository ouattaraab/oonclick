# ========================
# Backend Laravel (oonclick-api)
# ========================
# Tous les fichiers .env sauf .env.example
oonclick-api/.env
oonclick-api/.env.*
!oonclick-api/.env.example
# Sécurité — ne jamais versionner ces fichiers même s'ils sont créés par erreur
oonclick-api/.env.local
oonclick-api/.env.production
oonclick-api/.env.staging
oonclick-api/vendor/
oonclick-api/node_modules/
oonclick-api/storage/logs/*
oonclick-api/storage/framework/cache/*
oonclick-api/storage/framework/sessions/*
oonclick-api/storage/framework/views/*
oonclick-api/bootstrap/cache/*.php
oonclick-api/public/storage
oonclick-api/.phpunit.result.cache
oonclick-api/coverage/

# ========================
# Mobile Flutter (oonclick-mobile)
# ========================
oonclick-mobile/.dart_tool/
oonclick-mobile/.flutter-plugins
oonclick-mobile/.flutter-plugins-dependencies
oonclick-mobile/build/
oonclick-mobile/ios/Pods/
oonclick-mobile/ios/.symlinks/
oonclick-mobile/android/.gradle/
oonclick-mobile/android/local.properties
oonclick-mobile/android/key.properties
oonclick-mobile/*.keystore
oonclick-mobile/*.jks
oonclick-mobile/pubspec.lock

# ========================
# Global
# ========================
.DS_Store
*.log
.idea/
.vscode/
*.swp
*.swo
Thumbs.db

# ========================
# Secrets — ne JAMAIS versionner
# ========================
# Clés et certificats
*.pem
*.p12
*.pfx
*.key
*.crt
*.cer
google-services.json
GoogleService-Info.plist
firebase-credentials.json

# Fichiers de credentials divers
*credentials*
*secrets*
*secret*
*.keystore
service-account*.json

# Outils de scan locaux
.gitleaks.toml
.secrets.baseline
